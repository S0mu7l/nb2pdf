# Python
__pycache__/
*.py[cod]
nb2pdf/_buildlang.py
*.egg-info/
.eggs/
*.egg
dist-packages/

# Virtual environments
.venv/
venv/
env/

# PyInstaller build artifacts / 打包中间产物
build/
dist/

# App icon assets — local / build-time only
# 应用图标资源，本地生成，不提交 git
assets/

# Release dir — publish via GitHub Releases, not git
# 发布目录通过 Releases 分发，不提交 git
release/

# PNG images — binary assets, not tracked
# PNG 图片为二进制资源，不提交 git
*.png

# Build scripts & samples — local only / 不上传：打包脚本与示例
scripts/
examples/
requirements-build.txt

# IDE / editor / local tooling
.vscode/
.specstory/
.cursorindexingignore

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs & temp
*.log
*.tmp
